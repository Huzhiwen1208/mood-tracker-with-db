APP_PORT=9090
SESSION_COOKIE_NAME=mood_tracker_session

DB_MODE=tcp
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=mood_tracker_app
# 宿主机映射端口，仅在需要从宿主机直连 MySQL 时使用
DB_PORT_FORWARD=3307
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_DELAY_MS=2000

# 仅在 DB_MODE=docker-exec 时需要
# DB_CONTAINER_ID=your-mysql-container-name

ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=Admin123!@#
ADMIN_NICKNAME=系统管理员
SESSION_DAYS=7
